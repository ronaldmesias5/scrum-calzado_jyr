# ============================================================
# CALZADO J&R — Variables de Entorno (Plantilla raíz)
# ============================================================
# ¿Qué?    Plantilla con TODAS las variables que necesita
#           docker-compose.yml para levantar el stack completo.
# ¿Para?   Un solo archivo .env en la raíz del proyecto configura
#           simultáneamente la BD, el backend y el frontend.
# ¿Impacto? Centraliza la configuración: un cambio aquí afecta
#           a todos los servicios. El .env NUNCA se versiona en git.
#
# INSTRUCCIONES:
#   cp .env.example .env
#   Editar .env con valores reales para tu entorno.
# ============================================================

# ====================================================================
# 🐘 PostgreSQL — Base de datos
# ====================================================================
# REQUERIDO. Formato: postgresql://usuario:contraseña@host:puerto/dbname
# Ejemplo: postgresql://jyr_user:MiContraseña123@localhost:5432/calzado_jyr_db
DATABASE_URL=postgresql://jyr_user:cambia_esta_contrasena_segura@db:5432/calzado_jyr_db

# Usuario PostgreSQL
POSTGRES_USER=jyr_user

# Contraseña PostgreSQL (misma que en DATABASE_URL)
# ⚠️ NUNCA dejar vacío. Generar: openssl rand -base64 24
POSTGRES_PASSWORD=cambia_esta_contrasena_segura

# Nombre de la base de datos
POSTGRES_DB=calzado_jyr_db

# Puerto expuesto al host
DB_PORT=5432

# ====================================================================
# 🔐 JWT y Seguridad — Backend
# ====================================================================

# Clave secreta para firmar tokens JWT
# ⚠️​ CAMBIAR OBLIGATORIAMENTE. Generar:
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CAMBIA_ESTO_genera_con_secrets_token_urlsafe_48

# Algoritmo de firma JWT
ALGORITHM=HS256

# Duración del access token en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Duración del refresh token en días
REFRESH_TOKEN_EXPIRE_DAYS=7

# ====================================================================
# 📧 Email — Recuperación de contraseña
# ====================================================================
# REQUERIDO para recuperación de contraseña (recuperación de contraseña deshabilitada si vacío)

# Servidor SMTP
# Ejemplos: smtp.gmail.com, smtp.office365.com, smtp.sendgrid.net
MAIL_SERVER=smtp.gmail.com

# Puerto SMTP (587=TLS, 465=SSL, 25=sin cifrado)
MAIL_PORT=587

# Email/usuario SMTP
# REQUERIDO si MAIL_SERVER está configurado
MAIL_USERNAME=tu-email@gmail.com

# Contraseña o App Password SMTP
# REQUERIDO si MAIL_SERVER está configurado
# ====================================================================
# 🌐 URLs de servicios
# ====================================================================
# REQUERIDO para CORS y comunicación entre servicios

# URL del frontend (usada por backend para CORS)
# En desarrollo: http://localhost:5173
# En producción: https://tu-dominio.com
FRONTEND_URL=http://localhost:5173

# URL del backend (usada por frontend para peticiones API)
# En desarrollo: http://localhost:8000
# En producción: https://api.tu-dominio.com
# 🌐 URLs de servicios
# ════════════════════════════════════

# URL del frontend — usada por el backend para configurar CORS.
# En desarrollo local coincide con el puerto de Vite.
FRONTEND_URL=http://localhost:5173

# URL del backend — usada por Vite para las peticiones API.
# En desarrollo local coincide con el puerto de Uvicorn.
VI════════════════════════════════════
# 🔌 Puertos expuestos al host
# ════════════════════════════════════
# Cambiar si hay conflictos locales

BE_PORT=8000
FE_PORT=5173

# ════════════════════════════════════
# 🏢 Ambiente
# ════════════════════════════════════
# Valores: development, production
ENVIRONMENT=developmenti hay conflictos con otros servicios locales)
# ════════════════════════════════════
BE_PORT=8000
FE_PORT=5173
