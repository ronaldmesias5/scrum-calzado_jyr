# ============================================================
# CALZADO J&R — Variables de Entorno (ÚNICO .env.example)
# ============================================================
# Este es el ÚNICO archivo .env.example del proyecto.
# Los archivos be/.env.example y fe/.env.example están OBSOLETOS.
#
# INSTRUCCIONES:
#   cp .env.example .env
#   Editar .env con valores reales para tu entorno.
#   NUNCA versionar .env en git.
# ============================================================

# ════════════════════════════════════════
# 🐘 PostgreSQL — Base de datos
# ════════════════════════════════════════
# Para Docker:     host=db
# Para local:      host=localhost
DATABASE_URL=postgresql://CHANGE_ME_USER:CHANGE_ME_PASSWORD@db:5432/calzado_jyr_db
POSTGRES_USER=CHANGE_ME_USER
POSTGRES_PASSWORD=CHANGE_ME_PASSWORD
POSTGRES_DB=calzado_jyr_db
DB_PORT=5432

# ════════════════════════════════════════
# 🔐 JWT y Seguridad
# ════════════════════════════════════════
# Generar SECRET_KEY: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_GENERATE_WITH_secrets_token_urlsafe_48
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ════════════════════════════════════════
# 📧 Email — Recuperación de contraseña
# ════════════════════════════════════════
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=CHANGE_ME_EMAIL@gmail.com
MAIL_PASSWORD=CHANGE_ME_APP_PASSWORD

# ════════════════════════════════════════
# 🌐 URLs de servicios
# ════════════════════════════════════════
FRONTEND_URL=http://localhost:5173
VITE_API_URL=http://localhost:8000

# ════════════════════════════════════════
# 🔌 Puertos expuestos al host
# ════════════════════════════════════════
BE_PORT=8000
FE_PORT=5173

# ════════════════════════════════════════
# 🏢 Ambiente (development | production)
# ════════════════════════════════════════
ENVIRONMENT=development
