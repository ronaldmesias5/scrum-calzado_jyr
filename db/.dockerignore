# ============================================================
# .dockerignore — Archivos a ignorar al construir imagen Docker
# ============================================================
# Especifica qué archivos/carpetas debe ignorar Docker al
# construir el contexto (por si se usa build ./db en el futuro).
#
# Reduce el tamaño del contexto de build y acelera construcción.
# ============================================================

# Git
.git
.gitignore
.gitattributes

# Sistema operativo
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Logs y temporales
*.log
*.tmp
*.bak

# IDEs
.vscode/
.idea/
*.code-workspace
*.sublime-project
*.sublime-workspace

# Node.js (si llegara a haber)
node_modules/
npm-debug.log
pnpm-lock.yaml

# Python (si llegara a haber)
__pycache__/
*.py[cod]
*$py.class
.Python
*.egg-info/
dist/
build/

# Documentación generada (readme local puede quedarse)
docs/
examples/

# Archivos de configuración local (no necesarios en image)
.env
.env.local
.env.*.local

# ============================================================
# NOTA: Se mantiene:
# - init/ (scripts SQL)
# - Dockerfile
# - README.md (documentación)
# - todo lo necesario para el bootstrap técnico
# ============================================================
